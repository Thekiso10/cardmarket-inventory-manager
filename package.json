{
  "name": "cardmarket-inventory-manager",
  "version": "1.0.1",
  "description": "Scraper de ofertas publicas de Cardmarket y sincronizacion con PostgreSQL/Supabase.",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "sync": "tsx src/index.ts sync",
    "scrape": "tsx src/index.ts scrape",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.7",
    "pg": "^8.20.0",
    "puppeteer": "^24.42.0",
    "puppeteer-real-browser": "^1.4.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
