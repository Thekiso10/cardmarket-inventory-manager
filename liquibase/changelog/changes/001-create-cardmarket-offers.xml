<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-cardmarket-offers" author="codex">
        <createTable tableName="cardmarket_offers">
            <column name="card_name" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="normalized_card_name" type="TEXT">
                <constraints primaryKey="true" primaryKeyName="pk_cardmarket_offers" nullable="false"/>
            </column>
            <column name="is_foil" type="BOOLEAN" defaultValueBoolean="false">
                <constraints primaryKey="true" primaryKeyName="pk_cardmarket_offers" nullable="false"/>
            </column>
            <column name="sale_url" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="collection" type="TEXT"/>
            <column name="rarity" type="TEXT"/>
            <column name="language" type="TEXT"/>
            <column name="condition" type="TEXT"/>
            <column name="observation" type="TEXT"/>
            <column name="normalized_observation" type="TEXT" defaultValue="">
                <constraints primaryKey="true" primaryKeyName="pk_cardmarket_offers" nullable="false"/>
            </column>
            <column name="price_cents" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="price_currency" type="VARCHAR(3)" defaultValue="EUR">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="source_article_id" type="BIGINT"/>
            <column name="source_page" type="INTEGER"/>
            <column name="last_seen_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="cardmarket_offers" indexName="idx_cardmarket_offers_card_name">
            <column name="card_name"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
